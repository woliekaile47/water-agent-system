# Added by Codex for water_agent_system local Git hygiene
# Python
__pycache__/
*.pyc
.venv/
venv/

# ROS / colcon
build/
install/
log/

# Raw rosbag / large sensor data
*.db3
*.mcap
*.bag
*.bag/
*.pcd
*.ply

# Phase 1 simulation cases are reproducible generated artifacts. Keep only
# the directory placeholder; source, configuration, and tests live under
# simulation/ and remain tracked.
data/simulation/*
!data/simulation/.gitkeep

# Explicit generated simulation artifact types (defence in depth)
data/simulation/**/rosbag/
data/simulation/**/*.db3
data/simulation/**/*.mcap
data/simulation/**/*.obj
data/simulation/**/*.mtl
data/simulation/**/*.npy
data/simulation/**/*.png
data/simulation/**/resolved_world.sdf
data/simulation/**/manifest.json

# Large generated arrays
*.npy
*.npz

# SQLite runtime database
data/db/*.db
data/db/*.sqlite
data/db/*.sqlite3

# Cache / system
.cache/
.DS_Store

# Temporary files
*.tmp
*.bak
*.swp
