# Added by Codex for water_agent_system local Git hygiene
# Python
__pycache__/
*.pyc
.venv/
venv/

# ROS / colcon
build/
install/
log/

# Raw rosbag / large sensor data
*.db3
*.mcap
*.bag
*.bag/
*.pcd
*.ply

# Phase 1 simulation cases are reproducible generated artifacts. Keep only
# the directory placeholder; source, configuration, and tests live under
# simulation/ and remain tracked.
data/simulation/*
!data/simulation/.gitkeep

# Explicit generated simulation artifact types (defence in depth)
data/simulation/**/rosbag/
data/simulation/**/*.db3
data/simulation/**/*.mcap
data/simulation/**/*.obj
data/simulation/**/*.mtl
data/simulation/**/*.npy
data/simulation/**/*.png
data/simulation/**/resolved_world.sdf
data/simulation/**/manifest.json

# Phase 2 simulation evaluation outputs are reproducible local artifacts.
# Keep them on disk for Phase 2B comparisons, but do not commit generated
# NPY, PNG, JSON, CSV, or report files.
outputs/simulation_evaluation/
outputs/simulation_evaluation_v2/

# Phase 2C-1 generated visual sequences and previews. Preserve only the
# dataset root placeholder; frames, labels, manifests and summaries are local.
data/simulation_dynamic/*
!data/simulation_dynamic/.gitkeep
outputs/dynamic_visual_simulation/
outputs/temporal_water_detection/
outputs/temporal_event_classifier/
outputs/temporal_water_detection_model/
outputs/synthetic_visual_to_depth_integration/
outputs/temporal_sam2_prompt_heldout_*/
outputs/sam2_auto_prompt_heldout_*/
outputs/sam2_auto_prompt_gt_evaluation_*/
outputs/sam2_auto_prompt_failure_audit_*/
outputs/sam2_video_pilot*/
outputs/sam2_video_geometry_stability_*/
outputs/sam2_video_geometry_gt_evaluation_*/

# Phase 2D-C manually prompted SAM 2 geometry inputs and generated diagnostics
# are local experiment artifacts. Source adapters, tests, and documents remain tracked.
data/sam2_geometry_inputs/
outputs/sam2_shoreline_geometry/
outputs/sam2_shoreline_geometry_gt_evaluation/
outputs/sam2_shoreline_geometry_blind_*/
outputs/sam2_shoreline_geometry_gt_evaluation_blind_*/

# Large generated arrays
*.npy
*.npz

# SQLite runtime database
data/db/*.db
data/db/*.sqlite
data/db/*.sqlite3

# Cache / system
.cache/
.DS_Store

# Temporary files
*.tmp
*.bak
*.swp
